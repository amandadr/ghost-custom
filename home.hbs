{{!< default}}
{{! Homepage: colurs.md rhythm Cream → Paper → Olive → Maroon (work section deferred) }}

<main class="site-main mrc-home">
  {{! 1. Cream }}
  <section class="mrc-hero section-light gh-outer" aria-labelledby="mrc-hero-heading">
    <div class="mrc-hero-inner gh-inner mrc-stack mrc-stack--l">
      <h1 id="mrc-hero-heading" class="mrc-hero-headline">{{@custom.hero_headline}}</h1>
      <p class="mrc-hero-subtext">{{@custom.hero_subtext}}</p>
      <div class="mrc-hero-cta mrc-cluster mrc-cluster--center">
        <a
          href="/contact/"
          class="button mrc-btn-primary"
          data-ga-event="cta_click"
          data-ga-category="engagement"
          data-ga-label="home_hero_get_in_touch"
        >Get in touch</a>
        <a
          href="/services/"
          class="button mrc-btn-secondary"
          data-ga-event="cta_click"
          data-ga-category="engagement"
          data-ga-label="home_hero_services"
        >Services</a>
      </div>
    </div>
  </section>

  {{! 2. Paper — What I do }}
  <section class="mrc-section section-surface mrc-pillars-section gh-outer" aria-labelledby="mrc-pillars-title">
    <div class="mrc-section-inner gh-inner">
      <h2 id="mrc-pillars-title" class="mrc-section-title">What I do</h2>
      <div class="mrc-pillars mrc-grid mrc-grid--auto mrc-grid--gap-l">
        {{> "service-card" title="Systems & Technical Strategy" description="APIs, analytics, infrastructure — connected systems, not isolated features." link_url="https://docs.mannyroy.com/docs/category/architecture"}}
        {{> "service-card" title="Custom Software & Web Applications" description="Build it once. Maintain it well. Sustainable, measurable outcomes." link_url="https://docs.mannyroy.com/docs/category/getting-started"}}
        {{> "service-card" title="Automation & Applied AI" description="Data workflows and AI that integrate into real operations — not prototype theatre." link_url="https://docs.mannyroy.com/docs/category/ai-assistant"}}
      </div>
    </div>
  </section>

  {{! 3. Olive — How I work }}
  <section class="mrc-section section-dark mrc-principles-section gh-outer" aria-labelledby="mrc-principles-title">
    <div class="mrc-section-inner gh-inner">
      <h2 id="mrc-principles-title" class="mrc-section-title">How I work</h2>
      <div class="mrc-principles mrc-grid mrc-grid--auto mrc-grid--gap-l">
        {{> "principle-item" title="Sustainable" body="Build it once. Maintain it well."}}
        {{> "principle-item" title="Measurable" body="If it can be evaluated, it can be improved."}}
        {{> "principle-item" title="Collaborative" body="Works with internal teams, contractors, and stakeholders."}}
        {{> "principle-item" title="Evidence-based" body="Decisions grounded in data, not folklore."}}
      </div>
    </div>
  </section>

  {{! 4. Maroon — Final CTA }}
  {{> "cta-section" headline="Let's team up" subtext="Clear systems. Measurable impact." button_text="Get in touch"}}
</main>
