<footer class="gh-foot mrc-foot gh-outer">
  <div class="mrc-foot-inner gh-inner mrc-stack mrc-stack--l">
    <nav class="mrc-foot-nav" aria-label="Footer">
      {{navigation}}
    </nav>
    <div class="mrc-foot-main">
      <p class="mrc-foot-bio">{{@custom.footer_bio}}</p>
    </div>
    <div class="mrc-foot-bottom">
      <span class="mrc-foot-copy">{{@site.title}} © {{date format="YYYY"}}</span>
    </div>
  </div>
</footer>
