{{! Homepage hero: positioning clarity, small badge optional, CTAs }}
<section class="mrc-hero gh-outer">
  <div class="mrc-hero-inner gh-inner">
    {{#if @custom.header_logo}}
      <div class="mrc-hero-badge">
        <img class="mrc-hero-badge-img" src="{{@custom.header_logo}}" alt="" aria-hidden="true">
      </div>
    {{/if}}
    <h1 class="mrc-hero-headline">{{@custom.hero_headline}}</h1>
    <p class="mrc-hero-subtext">{{@custom.hero_subtext}}</p>
    <div class="mrc-hero-cta">
      <a
        href="/contact/"
        class="button mrc-btn-primary"
        data-ga-event="cta_click"
        data-ga-category="engagement"
        data-ga-label="hero_get_in_touch"
      >Get in touch</a>
      <a
        href="/services/"
        class="button button-secondary mrc-btn-secondary"
        data-ga-event="cta_click"
        data-ga-category="engagement"
        data-ga-label="hero_services"
      >Services</a>
    </div>
  </div>
</section>
