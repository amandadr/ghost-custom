{{! Final CTA — Maroon bg, Cream text, Mustard button + Ink (colurs.md) }}
<section class="mrc-cta-section section-cta gh-outer">
  <div class="mrc-cta-inner gh-inner mrc-stack mrc-stack--m">
    <h2 class="mrc-cta-headline">{{#if headline}}{{headline}}{{else}}Let's team up{{/if}}</h2>
    {{#if subtext}}
      <p class="mrc-cta-subtext">{{subtext}}</p>
    {{/if}}
    <a
      href="{{@site.url}}/contact/"
      class="button mrc-cta-btn"
      data-ga-event="cta_click"
      data-ga-category="engagement"
      data-ga-label="final_cta_get_in_touch"
    >{{#if button_text}}{{button_text}}{{else}}Get in touch{{/if}}</a>
  </div>
</section>
