  <div class="mrc-glossary__groups">
    <section class="mrc-glossary__group" aria-labelledby="glossary-a">
      <h3 id="glossary-a" class="mrc-glossary__letter">A</h3>
      <dl class="mrc-glossary__list">
        <dt id="glossary-api" class="mrc-glossary__term">API</dt>
        <dd class="mrc-glossary__def">A contract for how software systems communicate (inputs, outputs, errors, and guarantees).</dd>
      </dl>
    </section>

    <section class="mrc-glossary__group" aria-labelledby="glossary-b">
      <h3 id="glossary-b" class="mrc-glossary__letter">B</h3>
      <dl class="mrc-glossary__list">
        <dt id="glossary-blast-radius" class="mrc-glossary__term">Blast radius</dt>
        <dd class="mrc-glossary__def">How much of the system is affected when something fails or changes.</dd>
      </dl>
    </section>

    <section class="mrc-glossary__group" aria-labelledby="glossary-c">
      <h3 id="glossary-c" class="mrc-glossary__letter">C</h3>
      <dl class="mrc-glossary__list">
        <dt id="glossary-cache" class="mrc-glossary__term">Cache</dt>
        <dd class="mrc-glossary__def">Stored results used to avoid repeating expensive work (trade-off: freshness vs speed).</dd>
      </dl>
    </section>

    <section class="mrc-glossary__group" aria-labelledby="glossary-d">
      <h3 id="glossary-d" class="mrc-glossary__letter">D</h3>
      <dl class="mrc-glossary__list">
        <dt id="glossary-drift" class="mrc-glossary__term">Drift</dt>
        <dd class="mrc-glossary__def">When real system behavior slowly diverges from what’s documented or expected.</dd>
      </dl>
    </section>

    <section class="mrc-glossary__group" aria-labelledby="glossary-e">
      <h3 id="glossary-e" class="mrc-glossary__letter">E</h3>
      <dl class="mrc-glossary__list">
        <dt id="glossary-entropy" class="mrc-glossary__term">Entropy (systems)</dt>
        <dd class="mrc-glossary__def">The tendency for processes and codebases to get messier without deliberate maintenance.</dd>
      </dl>
    </section>

    <section class="mrc-glossary__group" aria-labelledby="glossary-f">
      <h3 id="glossary-f" class="mrc-glossary__letter">F</h3>
      <dl class="mrc-glossary__list">
        <dt id="glossary-failure-mode" class="mrc-glossary__term">Failure mode</dt>
        <dd class="mrc-glossary__def">A specific way a system can break, including its symptoms and triggers.</dd>
      </dl>
    </section>

