{{!< default}}
{{! Scout / reviewer landing page — Ghost Admin: Page slug "ghost-application", template "Ghost application". Avoid slug "ghost" (admin path). }}

<main class="site-main mrc-page mrc-page-ghost">
  {{! 1. Hero — Cream }}
  <section class="mrc-ghost-hero section-light gh-outer" aria-labelledby="mrc-ghost-hero-title">
    <div class="mrc-ghost-hero-inner gh-inner mrc-stack mrc-stack--m">
      <p class="mrc-ghost-hero-kicker">Portfolio guide</p>
      <h1 id="mrc-ghost-hero-title" class="mrc-ghost-hero-title">{{@custom.ghost_hero_title}}</h1>
      <p class="mrc-ghost-hero-subtext">{{@custom.ghost_hero_subtext}}</p>
      <p class="mrc-ghost-hero-meta">
        <a href="https://docs.mannyroy.com/docs/intro">Technical documentation</a>
        <span class="mrc-ghost-hero-meta-sep" aria-hidden="true">·</span>
        <a href="{{@site.url}}/blog/">Blog</a>
        <span class="mrc-ghost-hero-meta-sep" aria-hidden="true">·</span>
        <a href="{{@site.url}}/about/">About</a>
      </p>
    </div>
  </section>

  {{! 2. Capability → evidence matrix — Paper }}
  <section class="mrc-ghost-matrix section-surface gh-outer" aria-labelledby="mrc-ghost-matrix-title">
    <div class="mrc-ghost-matrix-inner gh-inner">
      <h2 id="mrc-ghost-matrix-title" class="mrc-ghost-section-title">What to look for → where it shows up</h2>
      <p class="mrc-ghost-matrix-lede">
        Use this as a checklist while you click through. Everything here is production code, public docs, or published writing—not slide decks. Each row links to a doc that backs up the claim.
      </p>
      <div class="mrc-ghost-matrix-rows">
        {{> "ghost-responsibility-row" heading="Systems & platform work" proof="Custom Ghost theme and asset pipeline, structured documentation site, reusable partials and conventions, AI assistant integrated for site exploration." doc_url="https://docs.mannyroy.com/docs/architecture/theme-system" doc_label="Theme system (Ghost)"}}
        {{> "ghost-responsibility-row" heading="Performance & reliability" proof="Core Web Vitals–oriented CSS/JS strategy, measurement notes in docs, deployment and rollback thinking." doc_url="https://docs.mannyroy.com/docs/performance/strategy" doc_label="Performance strategy & baselines"}}
        {{> "ghost-responsibility-row" heading="Documentation & DX" proof="Public docs hub (architecture, ops, AI design), onboarding and build docs, clear boundaries between theme vs content." doc_url="https://docs.mannyroy.com/docs/how-to-use-these-docs" doc_label="How to use these docs"}}
        {{> "ghost-responsibility-row" heading="Operations" proof="Observability and deployment narrative, validation workflow, transparent tradeoffs in writing." doc_url="https://docs.mannyroy.com/docs/operations/observability" doc_label="Observability & reliability"}}
        {{> "ghost-responsibility-row" heading="Communication" proof="Blog and tagged posts, technical tone in docs, this page as a deliberate entry point for reviewers." doc_url="https://docs.mannyroy.com/docs/benefits-and-outcomes" doc_label="Benefits, outcomes & narrative"}}
      </div>
    </div>
  </section>

  {{! 3. Implementation highlights — Olive }}
  <section class="mrc-ghost-highlights section-dark gh-outer" aria-labelledby="mrc-ghost-highlights-title">
    <div class="mrc-ghost-highlights-inner gh-inner">
      <h2 id="mrc-ghost-highlights-title" class="mrc-ghost-section-title">Start with these links</h2>
      <p class="mrc-ghost-highlights-lede">Each card points to a deep doc—skim one before a call, or read end-to-end.</p>
      <div class="mrc-ghost-highlights-grid mrc-grid mrc-grid--auto mrc-grid--gap-l">
        {{> "ghost-highlight-card" title="Theme & design system" description="Theme structure, CUBE CSS, partials, and how the Ghost theme fits the stack." doc_href="https://docs.mannyroy.com/docs/architecture/theme-system" link_label="-> Open Theme system (docs)"}}
        {{> "ghost-highlight-card" title="Design & components" description="Colour system, composition primitives, and accessibility targets for the UI." doc_href="https://docs.mannyroy.com/docs/design-system/overview" link_label="-> Open Design system overview"}}
        {{> "ghost-highlight-card" title="Documentation hub" description="How the docs are organized, who each quick-start is for, and where to read next." doc_href="https://docs.mannyroy.com/docs/architecture/overview" link_label="-> Open Architecture overview"}}
        {{> "ghost-highlight-card" title="Performance & assets" description="Strategy, scripts, fonts, and build-time choices that affect Core Web Vitals." doc_href="https://docs.mannyroy.com/docs/performance/strategy" link_label="-> Open Performance strategy"}}
        {{> "ghost-highlight-card" title="Asset pipeline" description="How CSS/JS are built, bundled, and shipped with the theme." doc_href="https://docs.mannyroy.com/docs/performance/scripts-and-assets" link_label="-> Open Scripts & assets"}}
        {{> "ghost-highlight-card" title="AI on the site" description="DocsGPT / Botty: privacy, widget integration, testing, and operations." doc_href="https://docs.mannyroy.com/docs/ai-assistant/docsgpt-overview" link_label="-> Open DocsGPT / Botty overview"}}
      </div>
    </div>
  </section>

  {{! 4. Explore + related posts — Paper }}
  <section class="mrc-ghost-links-section section-surface gh-outer" aria-labelledby="mrc-ghost-links-title">
    <div class="mrc-ghost-links-inner gh-inner">
      <h2 id="mrc-ghost-links-title" class="mrc-ghost-section-title">Explore the site</h2>
      <p class="mrc-ghost-links-lede">
        The <strong>blog</strong> is for narrative and updates; the <strong>docs</strong> are for specifications and runbooks. Use both to triangulate how I work.
      </p>
      <nav class="mrc-ghost-links mrc-cluster mrc-cluster--center" aria-label="Main destinations">
        <a href="https://docs.mannyroy.com/docs/intro" class="button mrc-btn-secondary">Documentation</a>
        <a href="{{@site.url}}/blog/" class="button mrc-btn-secondary">Blog</a>
        <a href="{{@site.url}}/about/" class="button mrc-btn-secondary">About</a>
        <a href="{{@site.url}}/contact/" class="button mrc-btn-primary">Contact</a>
      </nav>


      {{! Related posts: tag ghost-application (create in Admin → Tags) }}
      <div class="mrc-ghost-posts">
        <h3 class="mrc-ghost-posts-heading">{{@custom.ghost_posts_heading}}</h3>
        {{#get "posts" filter="tag:ghost-application" limit="5"}}
          <ul class="mrc-ghost-posts-list">
            {{#foreach posts}}
              <li><a href="{{url}}">{{title}}</a></li>
            {{else}}
              <li class="mrc-ghost-posts-empty-wrap"><p class="mrc-ghost-posts-empty">No posts yet. In Ghost Admin, create a tag with slug <code>ghost-application</code> and add it to posts you want featured here.</p></li>
            {{/foreach}}
          </ul>
        {{/get}}
      </div>
    </div>
  </section>

  {{! 5. CTA — Maroon }}
  {{> "cta-section" headline=@custom.ghost_cta_headline button_text=@custom.ghost_cta_button}}
</main>
