{{!< default}}
{{! Services page — slug "services". All copy editable via Settings → Design → Theme (Services). }}

<main class="site-main mrc-page mrc-page-services">
  {{! 1. Hero — Cream, centered, 65–75ch }}
  <section class="mrc-services-hero section-light gh-outer">
    <div class="mrc-services-hero-inner gh-inner mrc-stack mrc-stack--m">
      <h1 class="mrc-services-hero-title">{{@custom.services_hero_title}}</h1>
      <p class="mrc-services-hero-subtext">{{@custom.services_hero_subtext}}</p>
    </div>
    <div class="mrc-services-hero-divider"></div>
  </section>

  {{! 2. Services Overview — Paper, stacked sections }}
  <section class="mrc-services-overview section-surface gh-outer" aria-labelledby="mrc-services-overview-title">
    <div class="mrc-services-overview-inner gh-inner">
      {{> "service-section" slug="systems" title=@custom.services_sys_title intro=@custom.services_sys_intro include1=@custom.services_sys_1 include2=@custom.services_sys_2 include3=@custom.services_sys_3 include4=@custom.services_sys_4 ideal=@custom.services_sys_ideal}}

      {{> "service-section" slug="software" align="right" title=@custom.services_soft_title tagline=@custom.services_soft_tagline intro=@custom.services_soft_intro include1=@custom.services_soft_1 include2=@custom.services_soft_2 include3=@custom.services_soft_3 include4=@custom.services_soft_4 ideal=@custom.services_soft_ideal}}

      {{> "service-section" slug="automation" title=@custom.services_auto_title intro=@custom.services_auto_intro include1=@custom.services_auto_1 include2=@custom.services_auto_2 include3=@custom.services_auto_3 include4=@custom.services_auto_4 ideal=@custom.services_auto_ideal}}
    </div>
  </section>

  {{! 3. Engagement Model — Olive, Cream text }}
  <section class="mrc-engagement section-dark gh-outer" aria-labelledby="mrc-engagement-title">
    <div class="mrc-engagement-inner gh-inner">
      <h2 id="mrc-engagement-title" class="mrc-engagement-title">{{@custom.services_engage_heading}}</h2>
      <p class="mrc-engagement-intro">{{@custom.services_engage_p1}}</p>
      <p class="mrc-engagement-intro">{{@custom.services_engage_p2}}</p>
      <ul class="mrc-engagement-list">
        <li>{{@custom.services_engage_1}}</li>
        <li>{{@custom.services_engage_2}}</li>
        <li>{{@custom.services_engage_3}}</li>
        <li>{{@custom.services_engage_4}}</li>
      </ul>
    </div>
  </section>

  {{! 4. Process — Cream, 4 steps }}
  <section class="mrc-process section-light gh-outer" aria-labelledby="mrc-process-title">
    <div class="mrc-process-inner gh-inner">
      <h2 id="mrc-process-title" class="mrc-process-title">{{@custom.services_process_heading}}</h2>
      <div class="mrc-process-grid mrc-grid mrc-grid--auto mrc-grid--gap-l">
        {{> "process-step" title=@custom.services_process_1_title desc=@custom.services_process_1_desc}}
        {{> "process-step" title=@custom.services_process_2_title desc=@custom.services_process_2_desc}}
        {{> "process-step" title=@custom.services_process_3_title desc=@custom.services_process_3_desc}}
        {{> "process-step" title=@custom.services_process_4_title desc=@custom.services_process_4_desc}}
      </div>
    </div>
  </section>

  {{! 5. Final CTA — Maroon }}
  {{> "cta-section" headline=@custom.services_cta_headline subtext=@custom.services_cta_subtext button_text=@custom.services_cta_button}}
</main>
