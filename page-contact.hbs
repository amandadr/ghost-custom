{{!< default}}
{{! Contact page — URL slug "contact". All copy editable via Settings → Design → Theme (Contact). }}

<main class="site-main mrc-page mrc-page-contact">
  {{! 1. Hero — Cream, 65–75ch, mustard divider }}
  <section class="mrc-contact-hero section-light gh-outer" aria-labelledby="mrc-contact-hero-title">
    <div class="mrc-contact-hero-inner gh-inner mrc-stack mrc-stack--m">
      <h1 id="mrc-contact-hero-title" class="mrc-contact-hero-title">{{@custom.contact_hero_title}}</h1>
      <p class="mrc-contact-hero-subtext">{{@custom.contact_hero_subtext}}</p>
    </div>
    <div class="mrc-contact-hero-divider"></div>
  </section>

  {{! 2. Contact options — Paper, two-column: intro left, details right }}
  <section class="mrc-contact-options section-surface gh-outer" aria-labelledby="mrc-contact-intro-title">
    <div class="mrc-contact-options-inner gh-inner mrc-split mrc-split--60-40">
      <div class="mrc-contact-intro">
        <h2 id="mrc-contact-intro-title" class="mrc-contact-section-title">{{@custom.contact_intro_heading}}</h2>
        <p class="mrc-contact-p">{{@custom.contact_intro_p1}}</p>
        <p class="mrc-contact-p">{{@custom.contact_intro_p2}}</p>
      </div>
      <div class="mrc-contact-details">
        <p class="mrc-contact-detail-label">Email</p>
        <p class="mrc-contact-detail-value"><a href="mailto:{{@custom.contact_email}}?subject=Consulting%20inquiry">{{@custom.contact_email}}</a></p>
        <p class="mrc-contact-detail-label">Location</p>
        <p class="mrc-contact-detail-value">Souris, Prince Edward Island<br>Working with teams across Canada and the U.S.</p>
      </div>
    </div>
  </section>

  {{! 3. Contact form — Cream }}
  <section class="mrc-contact-form-section section-light gh-outer" aria-labelledby="mrc-contact-form-title">
    <div class="mrc-contact-form-inner gh-inner">
      <h2 id="mrc-contact-form-title" class="mrc-contact-section-title">Send a message</h2>
      <form class="mrc-contact-form" action="{{#if @custom.contact_form_action}}{{@custom.contact_form_action}}{{else}}https://formspree.io/f/YOUR_FORM_ID{{/if}}" method="POST" novalidate>
        <input type="hidden" name="_subject" value="Contact form submission from mannyroy.com">
        <input type="hidden" name="_next" value="{{@site.url}}/thanks/">
        <div class="mrc-form-field">
          <label for="mrc-contact-name">Name</label>
          <input type="text" id="mrc-contact-name" name="name" required autocomplete="name" minlength="1">
        </div>
        <div class="mrc-form-field">
          <label for="mrc-contact-email">Email</label>
          <input type="email" id="mrc-contact-email" name="email" required autocomplete="email">
        </div>
        <div class="mrc-form-field">
          <label for="mrc-contact-org">Organization <span class="mrc-form-optional">(optional)</span></label>
          <input type="text" id="mrc-contact-org" name="organization" autocomplete="organization">
        </div>
        <div class="mrc-form-field">
          <label for="mrc-contact-help">How can I help? <span class="mrc-form-optional">(optional)</span></label>
          <select id="mrc-contact-help" name="how_can_i_help" aria-label="How can I help?">
            <option value="">—</option>
            <option value="Systems & Strategy">Systems & Strategy</option>
            <option value="Custom Software">Custom Software</option>
            <option value="Automation & AI">Automation & AI</option>
            <option value="General Inquiry">General Inquiry</option>
          </select>
        </div>
        <div class="mrc-form-field">
          <label for="mrc-contact-message">Message</label>
          <textarea id="mrc-contact-message" name="message" rows="5" required minlength="1"></textarea>
        </div>
        <button type="submit" class="button mrc-contact-submit">Send Message</button>
      </form>
    </div>
  </section>

  {{! 4. What to expect — Olive anchor }}
  <section class="mrc-contact-expect section-dark gh-outer" aria-labelledby="mrc-contact-expect-title">
    <div class="mrc-contact-expect-inner gh-inner">
      <h2 id="mrc-contact-expect-title" class="mrc-contact-expect-title">{{@custom.contact_expect_heading}}</h2>
      <p class="mrc-contact-expect-p">{{@custom.contact_expect_p1}}</p>
      <p class="mrc-contact-expect-p">{{@custom.contact_expect_p2}}</p>
      <p class="mrc-contact-expect-p mrc-contact-expect-accent">{{@custom.contact_expect_accent}}</p>
    </div>
  </section>

  {{! 5. Final reassurance — Cream }}
  <section class="mrc-contact-reassurance section-light gh-outer" aria-labelledby="mrc-contact-reassurance-title">
    <div class="mrc-contact-reassurance-inner gh-inner">
      <h2 id="mrc-contact-reassurance-title" class="mrc-contact-section-title">{{@custom.contact_reassure_heading}}</h2>
      <p class="mrc-contact-p">{{@custom.contact_reassure_p}}</p>
    </div>
  </section>
</main>
