{
  "name": "manny-roy",
  "description": "Custom Ghost theme foundation for Manny Roy Consulting. Systems-focused, accessible, and built for clarity and sustainable technical storytelling.",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "ghost": ">=5.99.0"
  },
  "license": "MIT",
  "author": {
    "name": "Amanda Roy",
    "email": "manny@mannyroy.com",
    "url": "https://mannyroy.com"
  },
  "keywords": [
    "ghost-theme",
    "manny-roy-consulting",
    "technical",
    "systems",
    "accessible"
  ],
  "config": {
    "posts_per_page": 5,
    "image_sizes": {
      "xs": {
        "width": 150
      },
      "s": {
        "width": 400
      },
      "m": {
        "width": 750
      },
      "l": {
        "width": 960
      },
      "xl": {
        "width": 1140
      },
      "xxl": {
        "width": 1920
      }
    },
    "card_assets": true,
    "custom": {
      "navigation_layout": {
        "type": "select",
        "options": [
          "Logo on the left",
          "Logo in the middle",
          "Stacked"
        ],
        "default": "Logo on the left"
      },
      "title_font": {
        "type": "select",
        "options": [
          "Modern sans-serif",
          "Elegant serif"
        ],
        "default": "Modern sans-serif"
      },
      "body_font": {
        "type": "select",
        "options": [
          "Modern sans-serif",
          "Elegant serif"
        ],
        "default": "Modern sans-serif"
      },
      "color_scheme": {
        "type": "select",
        "options": [
          "Auto",
          "Light",
          "Dark"
        ],
        "default": "Auto"
      },
      "white_logo_for_dark_mode": {
        "type": "image"
      },
      "header_logo": {
        "type": "image",
        "description": "Logo for header, favicon, and social sharing. Leave empty for theme asset. Do not set Publication logo in Ghost."
      },
      "hero_headline": {
        "type": "text",
        "default": "Untangle complex technical and operational problems.",
        "group": "homepage"
      },
      "hero_subtext": {
        "type": "text",
        "default": "Sustainable systems rooted in data, collaboration, and measurable impact.",
        "group": "homepage"
      },
      "show_featured_posts": {
        "type": "boolean",
        "default": true,
        "group": "homepage"
      },
      "about_headshot": {
        "type": "image",
        "group": "about"
      },
      "show_author": {
        "type": "boolean",
        "default": true,
        "group": "post"
      },
      "show_related_posts": {
        "type": "boolean",
        "default": true,
        "group": "post"
      },
      "footer_bio": {
        "type": "text",
        "default": "Independent technical consultant. Systems, automation, applied AI. Souris, PEI."
      },
      "contact_email": {
        "type": "text",
        "default": "manny@mannyroy.com"
      },
      "contact_form_action": {
        "type": "text",
        "default": "https://formspree.io/f/YOUR_FORM_ID",
        "description": "Form submission URL (e.g. Formspree). Replace YOUR_FORM_ID with your form ID."
      },
      "ghost_hero_title": {
        "type": "text",
        "default": "A guided tour of how I build",
        "group": "ghost"
      },
      "ghost_hero_subtext": {
        "type": "text",
        "default": "This page is for recruiters and technical reviewers: a single map from this live site to documentation, writing, and implementation detail—so you can judge depth and craft without hunting through menus.",
        "group": "ghost"
      },
      "ghost_cta_headline": {
        "type": "text",
        "default": "Want to go deeper or start a conversation?",
        "group": "ghost"
      },
      "ghost_cta_button": {
        "type": "text",
        "default": "Get in touch",
        "group": "ghost"
      },
      "ghost_posts_heading": {
        "type": "text",
        "default": "Selected posts (tagged for this page)",
        "group": "ghost"
      }
    }
  },
  "resolutions": {
    "chalk": "4.1.2"
  },
  "scripts": {
    "dev": "gulp",
    "test": "gscan .",
    "zip": "gulp zip"
  },
  "devDependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@tryghost/shared-theme-assets": "2.5.2",
    "autoprefixer": "10.4.27",
    "beeper": "2.1.0",
    "cssnano": "7.1.2",
    "gscan": "5.2.5",
    "gulp": "5.0.1",
    "gulp-concat": "2.6.1",
    "gulp-livereload": "4.0.2",
    "gulp-postcss": "10.0.0",
    "gulp-uglify": "3.0.2",
    "postcss": "8.5.6",
    "postcss-easy-import": "4.0.0",
    "pump": "3.0.3"
  }
}
