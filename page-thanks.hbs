{{!< default}}
{{! Thanks page — shown after contact form submit. URL slug "thanks". Copy editable via Settings → Design → Theme (Thanks). }}

<main class="site-main mrc-page mrc-page-thanks">
  <section class="mrc-thanks section-light gh-outer" aria-labelledby="mrc-thanks-title">
    <div class="mrc-thanks-inner gh-inner">
      <h1 id="mrc-thanks-title" class="mrc-thanks-title">{{@custom.thanks_title}}</h1>
      <p class="mrc-thanks-p">{{@custom.thanks_body}}</p>
      <p class="mrc-thanks-back"><a href="{{@site.url}}/">Back to home</a></p>
    </div>
  </section>
</main>
