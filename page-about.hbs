{{!< default}}
{{! About page — URL slug "about". Rhythm: Cream → Paper → Olive → Cream → Paper → Maroon. All copy editable via Settings → Design → Theme (About). }}

<main class="site-main mrc-page mrc-page-about">
  {{! 1. Hero — Cream, 70ch }}
  <section class="mrc-about-hero section-light gh-outer" aria-labelledby="mrc-about-hero-title">
    <div class="mrc-about-hero-inner gh-inner mrc-stack mrc-stack--m">
      <h1 id="mrc-about-hero-title" class="mrc-about-hero-title">{{@custom.about_hero_title}}</h1>
      <p class="mrc-about-hero-subtext">{{@custom.about_hero_subtext}}</p>
    </div>
    <div class="mrc-about-hero-divider"></div>
  </section>

  {{! 2. Intro — Paper, 60/40 split }}
  {{> "two-column-section" section_class="surface" heading_id="mrc-about-intro-title" heading=@custom.about_intro_heading right_placeholder="true" p1=@custom.about_intro_p1 p2=@custom.about_intro_p2 p3=@custom.about_intro_p3 p4=@custom.about_intro_p4}}

  {{! 3. Why This Work Exists — Olive anchor }}
  <section class="mrc-about-why-anchor section-dark gh-outer" aria-labelledby="mrc-about-why-title">
    <div class="mrc-about-why-inner gh-inner">
      <h2 id="mrc-about-why-title" class="mrc-about-why-title">{{@custom.about_why_heading}}</h2>
      <p class="mrc-about-statement">{{@custom.about_why_lead}}</p>
      <ul class="mrc-about-why-list">
        <li>{{@custom.about_why_1}}</li>
        <li>{{@custom.about_why_2}}</li>
        <li>{{@custom.about_why_3}}</li>
        <li>{{@custom.about_why_4}}</li>
      </ul>
      <p class="mrc-about-statement">{{@custom.about_why_after}}</p>
      <p class="mrc-about-statement">{{@custom.about_why_after2}}</p>
      <div class="mrc-about-why-divider" aria-hidden="true"></div>
      <p class="mrc-about-statement mrc-about-statement-accent">{{@custom.about_why_accent}}</p>
      <p class="mrc-about-statement">{{@custom.about_why_f1}}</p>
      <p class="mrc-about-statement">{{@custom.about_why_f2}}</p>
      <p class="mrc-about-statement">{{@custom.about_why_f3}}</p>
    </div>
  </section>

  {{! 4. Experience — Cream, two cards with intro/outro copy }}
  <section class="mrc-about-experience section-light gh-outer" aria-labelledby="mrc-about-experience-title">
    <div class="mrc-about-experience-inner gh-inner">
      <h2 id="mrc-about-experience-title" class="mrc-about-section-title">{{@custom.about_exp_heading}}</h2>
      <div class="mrc-about-cards mrc-grid mrc-grid--auto mrc-grid--gap-l">
        <div class="mrc-about-card">
          <h3 class="mrc-about-card-title">{{@custom.about_tech_title}}</h3>
          <p class="mrc-about-card-intro">{{@custom.about_tech_intro}}</p>
          <ul class="mrc-about-card-list">
            <li>{{@custom.about_tech_1}}</li>
            <li>{{@custom.about_tech_2}}</li>
            <li>{{@custom.about_tech_3}}</li>
            <li>{{@custom.about_tech_4}}</li>
            <li>{{@custom.about_tech_5}}</li>
            <li>{{@custom.about_tech_6}}</li>
          </ul>
          <p class="mrc-about-card-outro">{{@custom.about_tech_outro}}</p>
        </div>
        <div class="mrc-about-card">
          <h3 class="mrc-about-card-title">{{@custom.about_ind_title}}</h3>
          <p class="mrc-about-card-intro">{{@custom.about_ind_intro}}</p>
          <p class="mrc-about-card-subhead">{{@custom.about_ind_subhead}}</p>
          <ul class="mrc-about-card-list">
            <li>{{@custom.about_ind_1}}</li>
            <li>{{@custom.about_ind_2}}</li>
            <li>{{@custom.about_ind_3}}</li>
            <li>{{@custom.about_ind_4}}</li>
          </ul>
          <p class="mrc-about-card-outro">{{@custom.about_ind_outro}}</p>
        </div>
      </div>
    </div>
  </section>

  {{! 5. Outside of Work — Paper }}
  <section class="mrc-about-beyond section-surface gh-outer" aria-labelledby="mrc-about-beyond-title">
    <div class="mrc-about-prose-inner gh-inner">
      <h2 id="mrc-about-beyond-title" class="mrc-about-section-title">{{@custom.about_beyond_heading}}</h2>
      <p class="mrc-about-prose-p">{{@custom.about_beyond_p1}}</p>
      <p class="mrc-about-prose-p">{{@custom.about_beyond_p2}}</p>
      <p class="mrc-about-prose-p">{{@custom.about_beyond_p3}}</p>
    </div>
  </section>

  {{! 6. Final CTA — Maroon }}
  {{> "cta-section" headline=@custom.about_cta_headline button_text=@custom.about_cta_button}}
</main>
